									"    pm.expect(res.data).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Metadata contains pagination info\", function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res.metadata).to.have.property(\"page\");",
									"    pm.expect(res.metadata).to.have.property(\"per_page\");",
									"    pm.expect(res.metadata).to.have.property(\"count\");",
									"});"
